        tweenService:Create(accentBar, TweenInfo.new(0.2), {BackgroundTransparency = toggled and 0 or 1}):Play()
        tweenService:Create(checkMark, TweenInfo.new(0.15), {TextTransparency = toggled and 0 or 1}):Play()
        tweenService:Create(checkStroke, TweenInfo.new(0.15), {Color = toggled and C.ACCENT or C.DIM}):Play()
        tweenService:Create(lbl, TweenInfo.new(0.15), {TextColor3 = toggled and C.ACCENT2 or C.WHITE}):Play()
        particles.setEnabled(toggled)
        
        -- Call callback with state and reset function
        callback(toggled, resetButton)
    end)

    btn.MouseEnter:Connect(function()
        if not toggled then
            tweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(26, 30, 44)}):Play()
            tweenService:Create(btnStroke, TweenInfo.new(0.1), {Transparency = 0.65}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if not toggled then
            tweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.BTN}):Play()
            tweenService:Create(btnStroke, TweenInfo.new(0.1), {Transparency = 0.85}):Play()
        end
    end)
end

