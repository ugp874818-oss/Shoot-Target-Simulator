local angle = 0
local ringConnection = nil
local pulseConnection = nil

local function startRingAnimation()
    if ringConnection then ringConnection:Disconnect() end
    ringConnection = runService.RenderStepped:Connect(function()
        if openCircle.Visible then
            angle = angle + 2
            ring.Rotation = angle
        end
    end)
end

local function stopRingAnimation()
    if ringConnection then
        ringConnection:Disconnect()
        ringConnection = nil
    end
end

local function startPulseEffect()
    if pulseConnection then pulseConnection:Disconnect() end
    pulseConnection = runService.Heartbeat:Connect(function()
        if openCircle.Visible then
            local pulse = (math.sin(tick() * 3) + 1) / 2
            local r = 0 + (0 * pulse)
            local g = 170 + (85 * pulse)
            local b = 255 + (0 * pulse)
            ring.BorderColor3 = Color3.fromRGB(r, g, b)
            icon.TextColor3 = Color3.fromRGB(r, g, b)
        end
    end)
end

closeBtn.MouseButton1Click:Connect(function()
    mainFrame:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.3, true, function()
        mainFrame.Visible = false
        openCircle.Visible = true
        openCircle.Size = UDim2.new(0, 0, 0, 0)
        openCircle:TweenSize(UDim2.new(0, 50, 0, 50), "Out", "Back", 0.3, true, function()
            startRingAnimation()
            startPulseEffect()
        end)
    end)
end)

openCircle.MouseButton1Click:Connect(function()
    stopRingAnimation()
    if pulseConnection then pulseConnection:Disconnect() end
    openCircle:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.3, true, function()
        openCircle.Visible = false
        mainFrame.Visible = true
        mainFrame:TweenSize(UDim2.new(0, SIZE.MAIN_W, 0, SIZE.MAIN_H), "Out", "Back", 0.3)
    end)
end)

local dragging = nil
local dragStart = nil
local startPos = nil

local function makeDraggable(obj)
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = obj
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
end

userInputService.InputChanged:Connect(function(input)
    if dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        local delta = input.Position - dragStart
        dragging.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = nil
        dragStart = nil
        startPos = nil
    end
end)

makeDraggable(mainFrame)
makeDraggable(openCircle)
