local function createParticleContainer(parent)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.ZIndex = 8
    container.ClipsDescendants = false
    container.Name = "ParticleContainer"
    container.Parent = parent

    local enabled = false
    local particles = {}
    local spawnConnection = nil

    local function spawnDot()
        if not enabled then return end
        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
        dot.Position = UDim2.new(math.random(0, 100) / 100, 0, math.random(0, 100) / 100, 0)
        dot.BackgroundColor3 = math.random() > 0.5 and C.ACCENT or C.ACCENT2
        dot.BackgroundTransparency = 0.2
        dot.BorderSizePixel = 0
        dot.ZIndex = 9
        dot.Parent = container
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

        table.insert(particles, dot)

        local tween = tweenService:Create(dot, TweenInfo.new(math.random(8, 16) / 10, Enum.EasingStyle.Quad), {
            BackgroundTransparency = 1,
            Position = UDim2.new(
                dot.Position.X.Scale + (math.random(-20, 20) / 100), 0,
                dot.Position.Y.Scale - math.random(5, 20) / 100, 0
            )
        })
        tween:Play()
        tween.Completed:Connect(function()
            dot:Destroy()
            for i, v in ipairs(particles) do
                if v == dot then table.remove(particles, i) break end
            end
        end)
    end

    return {
        setEnabled = function(state)
            enabled = state
            if state then
                if spawnConnection then spawnConnection:Disconnect() end
                spawnConnection = game:GetService("RunService").Heartbeat:Connect(function()
                    spawnDot()
                    task.wait(0.08)
                end)
            else
                if spawnConnection then 
                    spawnConnection:Disconnect()
                    spawnConnection = nil
                end
                for _, d in ipairs(particles) do
                    pcall(function() d:Destroy() end)
                end
                particles = {}
            end
        end,
        container = container
    }
end

