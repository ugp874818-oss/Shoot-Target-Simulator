    local function resetButton()
        if toggled then
            toggled = false
            tweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundColor3 = C.BTN
            }):Play()
            tweenService:Create(btnStroke, TweenInfo.new(0.2), {Transparency = 0.85}):Play()
