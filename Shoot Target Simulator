local function createSideTab(icon, label, pageFrame)
    local tab = Instance.new("TextButton")
    tab.Size = UDim2.new(0, SIZE.SIDE_W - 12, 0, SIZE.TAB_H)
    tab.BackgroundColor3 = C.SIDEBAR
    tab.AutoButtonColor = false
    tab.Text = ""
    tab.ZIndex = 3
    tab.Parent = tabContainer
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 6)

    local leftBar = Instance.new("Frame")
    leftBar.Name = "LeftBar"
    leftBar.Size = UDim2.new(0, 3, 0.6, 0)
    leftBar.Position = UDim2.new(0, 0, 0.2, 0)
    leftBar.BackgroundColor3 = C.ACCENT
    leftBar.BackgroundTransparency = 1
    leftBar.BorderSizePixel = 0
    leftBar.ZIndex = 4
    leftBar.Parent = tab
    Instance.new("UICorner", leftBar).CornerRadius = UDim.new(0, 2)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Name = "IconLabel"
    iconLbl.Size = UDim2.new(0, 20, 1, 0)
    iconLbl.Position = UDim2.new(0, 8, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icon
    iconLbl.TextColor3 = C.DIM
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.TextSize = 12
    iconLbl.TextXAlignment = Enum.TextXAlignment.Center
    iconLbl.TextYAlignment = Enum.TextYAlignment.Center
    iconLbl.ZIndex = 4
    iconLbl.Parent = tab

    local tabLbl = Instance.new("TextLabel")
    tabLbl.Name = "TabLabel"
    tabLbl.Size = UDim2.new(1, -32, 1, 0)
    tabLbl.Position = UDim2.new(0, 32, 0, 0)
    tabLbl.BackgroundTransparency = 1
    tabLbl.Text = label
    tabLbl.TextColor3 = C.MUTED
    tabLbl.Font = Enum.Font.GothamMedium
    tabLbl.TextSize = 11
    tabLbl.TextXAlignment = Enum.TextXAlignment.Left
    tabLbl.TextYAlignment = Enum.TextYAlignment.Center
    tabLbl.ZIndex = 4
    tabLbl.Parent = tab

    tabRefs[tab] = {leftBar = leftBar, iconLbl = iconLbl, tabLbl = tabLbl}

    local function activate()
        if activeSideTab and activeSideTab ~= tab then
            local oldRefs = tabRefs[activeSideTab]
            if oldRefs then
                tweenService:Create(activeSideTab, TweenInfo.new(0.2), {BackgroundColor3 = C.SIDEBAR}):Play()
                tweenService:Create(oldRefs.leftBar, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                tweenService:Create(oldRefs.tabLbl, TweenInfo.new(0.2), {TextColor3 = C.MUTED}):Play()
                tweenService:Create(oldRefs.iconLbl, TweenInfo.new(0.2), {TextColor3 = C.DIM}):Play()
            end
        end
        activeSideTab = tab
        tweenService:Create(tab, TweenInfo.new(0.2), {BackgroundColor3 = C.TAB_ACTV}):Play()
        tweenService:Create(leftBar, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        tweenService:Create(tabLbl, TweenInfo.new(0.2), {TextColor3 = C.WHITE}):Play()
        tweenService:Create(iconLbl, TweenInfo.new(0.2), {TextColor3 = C.ACCENT}):Play()

        for pg, linkedTab in pairs(tabPages) do
            pg.Visible = (linkedTab == tab)
        end
    end

    tab.MouseButton1Click:Connect(activate)

    if pageFrame then
        tabPages[pageFrame] = tab
    end

    tab.MouseEnter:Connect(function()
        if activeSideTab ~= tab then
            tweenService:Create(tab, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(22, 25, 36)}):Play()
        end
    end)
    tab.MouseLeave:Connect(function()
        if activeSideTab ~= tab then
            tweenService:Create(tab, TweenInfo.new(0.1), {BackgroundColor3 = C.SIDEBAR}):Play()
        end
    end)

    return tab, activate
end

